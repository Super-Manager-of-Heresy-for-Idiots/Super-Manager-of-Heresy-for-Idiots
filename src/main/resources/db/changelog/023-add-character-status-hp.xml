<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Add status, current_hp, and max_hp to characters -->
    <changeSet id="023-add-status-hp-to-characters" author="dnd-app">
        <addColumn tableName="characters">
            <column name="status" type="varchar(10)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="current_hp" type="int"/>
            <column name="max_hp" type="int"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
