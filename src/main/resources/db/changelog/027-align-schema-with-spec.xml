    <changeSet id="027-subclasses-add-homebrew" author="dnd-app">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="subclasses" columnName="homebrew_id"/>
            </not>
        </preConditions>
        <addColumn tableName="subclasses">
            <column name="homebrew_id" type="uuid"/>
        </addColumn>
        <addForeignKeyConstraint
                baseTableName="subclasses"
                baseColumnNames="homebrew_id"
                referencedTableName="homebrew_packages"
                referencedColumnNames="id"
                constraintName="fk_subclass_homebrew"
                onDelete="SET NULL"/>
    </changeSet>

