    <!-- character_classes -->
    <changeSet id="027-character-classes-rename-homebrew" author="dnd-app">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="character_classes" columnName="source_homebrew_id"/>
        </preConditions>
        <sql>ALTER TABLE character_classes DROP CONSTRAINT IF EXISTS fk_char_class_homebrew;</sql>
        <renameColumn tableName="character_classes"
                      oldColumnName="source_homebrew_id"
                      newColumnName="homebrew_id"
                      columnDataType="uuid"/>
        <addForeignKeyConstraint
                baseTableName="character_classes"
                baseColumnNames="homebrew_id"
                referencedTableName="homebrew_packages"
                referencedColumnNames="id"
                constraintName="fk_charclass_homebrew"
                onDelete="SET NULL"/>
    </changeSet>

    <changeSet id="027-character-classes-drop-owner" author="dnd-app">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="character_classes" columnName="owner_id"/>
        </preConditions>
        <sql>ALTER TABLE character_classes DROP CONSTRAINT IF EXISTS fk_char_class_owner;</sql>
        <dropColumn tableName="character_classes" columnName="owner_id"/>
    </changeSet>

