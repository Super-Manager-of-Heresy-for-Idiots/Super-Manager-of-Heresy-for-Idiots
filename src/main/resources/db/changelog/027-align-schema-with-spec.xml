    <changeSet id="027-migrate-unpublished-status" author="dnd-app">
        <sql>
            UPDATE homebrew_packages SET status = 'DRAFT' WHERE status = 'UNPUBLISHED';
        </sql>
    </changeSet>

</databaseChangeLog>
