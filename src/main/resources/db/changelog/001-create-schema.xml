<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-users" author="dnd-app">
        <createTable tableName="users">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="username" type="varchar(30)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="email" type="varchar(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password_hash" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="001-create-character-classes" author="dnd-app">
        <createTable tableName="character_classes">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="varchar(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="text"/>
        </createTable>
    </changeSet>

    <changeSet id="001-create-character-races" author="dnd-app">
        <createTable tableName="character_races">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="varchar(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="text"/>
        </createTable>
    </changeSet>

    <changeSet id="001-create-characters" author="dnd-app">
        <createTable tableName="characters">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="level" type="int" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="class_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_char_class" references="character_classes(id)"/>
            </column>
            <column name="race_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_char_race" references="character_races(id)"/>
            </column>
            <column name="owner_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_char_owner" references="users(id)"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="001-create-stat-types" author="dnd-app">
        <createTable tableName="stat_types">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="varchar(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="text"/>
            <column name="is_default" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="001-create-character-stats" author="dnd-app">
        <createTable tableName="character_stats">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="character_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_cstat_char" references="characters(id)" deleteCascade="true"/>
            </column>
            <column name="stat_type_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_cstat_type" references="stat_types(id)"/>
            </column>
            <column name="value" type="int" defaultValueNumeric="10">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="character_stats" columnNames="character_id, stat_type_id"
                             constraintName="uq_char_stat"/>
    </changeSet>

    <changeSet id="001-create-item-types" author="dnd-app">
        <createTable tableName="item_types">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="varchar(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="text"/>
            <column name="slot" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="001-create-inventory-slots" author="dnd-app">
        <createTable tableName="inventory_slots">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="character_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_inv_char" references="characters(id)" deleteCascade="true"/>
            </column>
            <column name="slot" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="item_type_id" type="uuid">
                <constraints foreignKeyName="fk_inv_item" references="item_types(id)"/>
            </column>
            <column name="quantity" type="int" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="varchar(255)"/>
        </createTable>
        <addUniqueConstraint tableName="inventory_slots" columnNames="character_id, slot"
                             constraintName="uq_char_slot"/>
    </changeSet>

    <changeSet id="001-create-teams" author="dnd-app">
        <createTable tableName="teams">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="varchar(80)">
                <constraints nullable="false"/>
            </column>
            <column name="game_master_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_team_gm" references="users(id)"/>
            </column>
            <column name="invite_code" type="varchar(8)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="001-create-team-members" author="dnd-app">
        <createTable tableName="team_members">
            <column name="team_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_tm_team" references="teams(id)" deleteCascade="true"/>
            </column>
            <column name="player_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_tm_player" references="users(id)"/>
            </column>
            <column name="joined_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="team_members" columnNames="team_id, player_id"
                       constraintName="pk_team_members"/>
    </changeSet>

</databaseChangeLog>
