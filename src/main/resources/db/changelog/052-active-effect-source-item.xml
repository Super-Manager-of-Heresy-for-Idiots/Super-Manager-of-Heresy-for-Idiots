<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      Ties an item-granted active effect to the specific item instance that applied it, so
      unequipping one item only removes its own buffs (two items granting the same buff no longer
      clobber each other). Nullable: manually-applied effects and pre-existing rows carry no source.
    -->
    <changeSet id="052-active-effect-source-item" author="claude">
        <addColumn tableName="character_active_effects">
            <column name="source_item_instance_id" type="uuid"/>
        </addColumn>
        <addForeignKeyConstraint
                baseTableName="character_active_effects"
                baseColumnNames="source_item_instance_id"
                constraintName="fk_active_effect_source_item_instance"
                referencedTableName="item_instances"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
