    <!-- ── Core rule + issue tables ──────────────────────────────────────────── -->
    <changeSet id="066-feature-rule-foundation-core" author="claude">
        <createTable tableName="feature_rule">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="owner_type" type="varchar(32)" defaultValue="CLASS_FEATURE">
                <constraints nullable="false"/>
            </column>
            <column name="owner_id" type="uuid"><constraints nullable="false"/></column>
            <column name="rule_type" type="varchar(48)"><constraints nullable="false"/></column>
            <column name="enabled" type="boolean" defaultValueBoolean="true"><constraints nullable="false"/></column>
            <column name="review_status" type="varchar(20)" defaultValue="draft"><constraints nullable="false"/></column>
            <column name="confidence" type="double precision"/>
            <column name="source" type="varchar(16)" defaultValue="manual"><constraints nullable="false"/></column>
            <column name="sort_order" type="integer" defaultValueNumeric="0"><constraints nullable="false"/></column>
            <column name="notes" type="text"/>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()"><constraints nullable="false"/></column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()"><constraints nullable="false"/></column>
        </createTable>

        <!-- Only CLASS_FEATURE ownership exists today, so a real FK protects integrity. Drop this FK when a
             second owner_type is introduced and validate ownership in the app layer instead. -->
        <addForeignKeyConstraint baseTableName="feature_rule" baseColumnNames="owner_id"
                                 referencedTableName="class_feature" referencedColumnNames="class_feature_id"
                                 constraintName="fk_feature_rule_owner_class_feature" onDelete="CASCADE"/>

        <createIndex tableName="feature_rule" indexName="idx_feature_rule_owner">
            <column name="owner_type"/>
            <column name="owner_id"/>
        </createIndex>
        <createIndex tableName="feature_rule" indexName="idx_feature_rule_type"><column name="rule_type"/></createIndex>
        <createIndex tableName="feature_rule" indexName="idx_feature_rule_status"><column name="review_status"/></createIndex>

        <createTable tableName="feature_rule_issue">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="owner_type" type="varchar(32)" defaultValue="CLASS_FEATURE">
                <constraints nullable="false"/>
            </column>
            <column name="owner_id" type="uuid"><constraints nullable="false"/></column>
            <column name="feature_rule_id" type="uuid"/>
            <column name="issue_type" type="varchar(48)"><constraints nullable="false"/></column>
            <column name="severity" type="varchar(16)"><constraints nullable="false"/></column>
            <column name="message" type="text"><constraints nullable="false"/></column>
            <column name="source_text_fragment" type="text"/>
            <column name="resolved" type="boolean" defaultValueBoolean="false"><constraints nullable="false"/></column>
            <column name="resolved_by" type="uuid"/>
            <column name="resolved_at" type="timestamp with time zone"/>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()"><constraints nullable="false"/></column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()"><constraints nullable="false"/></column>
        </createTable>

        <addForeignKeyConstraint baseTableName="feature_rule_issue" baseColumnNames="owner_id"
                                 referencedTableName="class_feature" referencedColumnNames="class_feature_id"
                                 constraintName="fk_feature_rule_issue_owner_class_feature" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="feature_rule_issue" baseColumnNames="feature_rule_id"
                                 referencedTableName="feature_rule" referencedColumnNames="id"
                                 constraintName="fk_feature_rule_issue_rule" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="feature_rule_issue" baseColumnNames="resolved_by"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_feature_rule_issue_resolved_by" onDelete="SET NULL"/>

        <createIndex tableName="feature_rule_issue" indexName="idx_feature_rule_issue_owner">
            <column name="owner_type"/>
            <column name="owner_id"/>
        </createIndex>
        <createIndex tableName="feature_rule_issue" indexName="idx_feature_rule_issue_rule"><column name="feature_rule_id"/></createIndex>
        <createIndex tableName="feature_rule_issue" indexName="idx_feature_rule_issue_open">
            <column name="resolved"/>
            <column name="severity"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
