<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      Feature rules runtime — Stage 1 schema foundation. See docs/FEATURE_RULES_RUNTIME_ROADMAP.md and
      anal-integration/01_STAGE_RULE_SCHEMA_FOUNDATION.md.

      class_feature.description stays the display source of truth. These tables give class-feature
      mechanics a normalized, reviewable, toggleable home:
        - feature_rule      : universal attach point + lifecycle (draft/needs_review/approved/disabled)
        - feature_rule_issue: real issue rows (replaces the single is_warning flag as the tracking model)
        - reference tables  : controlled vocabularies (rule types, statuses, action/rest/trigger/... types)

      feature_rule / feature_rule_issue use owner_type + owner_id so the same runtime can later be reused
      for race features, feats, items and homebrew. For now only CLASS_FEATURE is allowed, so owner_id has
      a real FK to class_feature; when a second owner type is added, that FK is dropped in a later migration
      and ownership is validated in the app layer instead.

      No runtime executes these rows yet; behavior is gated by app.feature-rules.* flags (all off).
    -->
    <changeSet id="066-feature-rule-foundation-ref-tables" author="claude">

        <!-- ── Reference / lookup tables ─────────────────────────────────────── -->
        <createTable tableName="feature_rule_type">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="varchar(48)"><constraints nullable="false" unique="true"
                                                                  uniqueConstraintName="uq_feature_rule_type_code"/></column>
            <column name="display_name" type="varchar(80)"><constraints nullable="false"/></column>
            <column name="sort_order" type="integer" defaultValueNumeric="0"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="rule_issue_type">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="varchar(48)"><constraints nullable="false" unique="true"
                                                                  uniqueConstraintName="uq_rule_issue_type_code"/></column>
            <column name="display_name" type="varchar(80)"><constraints nullable="false"/></column>
            <column name="sort_order" type="integer" defaultValueNumeric="0"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="review_status">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="varchar(32)"><constraints nullable="false" unique="true"
                                                                  uniqueConstraintName="uq_review_status_code"/></column>
            <column name="display_name" type="varchar(80)"><constraints nullable="false"/></column>
            <column name="sort_order" type="integer" defaultValueNumeric="0"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="action_type">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="varchar(32)"><constraints nullable="false" unique="true"
                                                                  uniqueConstraintName="uq_action_type_code"/></column>
            <column name="display_name" type="varchar(80)"><constraints nullable="false"/></column>
            <column name="sort_order" type="integer" defaultValueNumeric="0"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="rest_type">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="varchar(32)"><constraints nullable="false" unique="true"
                                                                  uniqueConstraintName="uq_rest_type_code"/></column>
            <column name="display_name" type="varchar(80)"><constraints nullable="false"/></column>
            <column name="sort_order" type="integer" defaultValueNumeric="0"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="trigger_event_type">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="varchar(48)"><constraints nullable="false" unique="true"
                                                                  uniqueConstraintName="uq_trigger_event_type_code"/></column>
            <column name="display_name" type="varchar(80)"><constraints nullable="false"/></column>
            <column name="sort_order" type="integer" defaultValueNumeric="0"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="target_type">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="varchar(32)"><constraints nullable="false" unique="true"
                                                                  uniqueConstraintName="uq_target_type_code"/></column>
            <column name="display_name" type="varchar(80)"><constraints nullable="false"/></column>
            <column name="sort_order" type="integer" defaultValueNumeric="0"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="duration_unit">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="varchar(32)"><constraints nullable="false" unique="true"
                                                                  uniqueConstraintName="uq_duration_unit_code"/></column>
            <column name="display_name" type="varchar(80)"><constraints nullable="false"/></column>
            <column name="sort_order" type="integer" defaultValueNumeric="0"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

