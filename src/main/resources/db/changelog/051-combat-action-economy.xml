<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      Per-combatant action economy. Tracks whether the combatant has spent their action, bonus
      action and reaction this turn so the combat UI can show what is still available. Flags reset
      when a combatant's turn begins.
    -->
    <changeSet id="051-combat-action-economy" author="claude">
        <addColumn tableName="battle_combatants">
            <column name="action_used" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="bonus_action_used" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="reaction_used" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
