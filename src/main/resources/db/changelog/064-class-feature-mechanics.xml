<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      Structured mechanics parsed from class_feature.description. The text remains
      authoritative for display, while these fields let runtime combat/level-up code
      use class features without reparsing prose on every request. is_warning marks
      features whose automatic parse needs admin review.
    -->
    <changeSet id="064-class-feature-mechanics" author="codex">
        <addColumn tableName="class_feature">
            <column name="activation_type" type="varchar(32)"/>
            <column name="is_attack_roll" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="save_ability" type="varchar(32)"/>
            <column name="damage_dice" type="varchar(40)"/>
            <column name="damage_type" type="varchar(32)"/>
            <column name="healing_dice" type="varchar(40)"/>
            <column name="healing_flat" type="integer"/>
            <column name="is_warning" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="warning_reason" type="text"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
