<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      custom_resource_types.class_bound_id was seeded (038-09) from the now-dropped legacy
      character_classes table, so it holds old class UUIDs (e.g. b0000000-...-0010) that do
      not exist in the new content table character_class. CustomResourceType.classBound now
      maps ContentCharacterClass -> character_class, so any attempt to materialise that FK
      (Hibernate auto-DDL, or a strict FK) fails on these dangling rows. This is the same
      orphan-cleanup as 063a, which did not cover this table.

      Runtime/seed binding data is disposable (no legacy backfill): NULL the dangling
      class_bound_id rather than remapping. The resource type itself keeps working; classBound
      is optional. Bestiary tables are NOT touched. Idempotent (no-op on a clean DB).
    -->
    <changeSet id="069-01-detach-custom-resource-class" author="content">
        <sql splitStatements="true" stripComments="false"><![CDATA[
UPDATE custom_resource_types crt
   SET class_bound_id = NULL
 WHERE crt.class_bound_id IS NOT NULL
   AND NOT EXISTS (SELECT 1 FROM character_class cc WHERE cc.class_id = crt.class_bound_id);
]]></sql>
        <rollback/>
    </changeSet>

</databaseChangeLog>
