<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      Phase 5: character creation can now store NEW content-model IDs in the shared
      runtime tables. These two columns historically FK to the legacy plural tables
      (character_classes / proficiency_skills); during the migration a character may
      reference either the legacy row or the new content row (character_class / skill),
      so the physical FK is relaxed (NO_CONSTRAINT semantics, mirroring the other
      transitional associations). Phase 10 migrates the data and Phase 12 re-adds a real
      FK to the new model. Idempotent: drops only if present.
    -->
    <changeSet id="060-01-relax-runtime-content-fks" author="content">
        <sql splitStatements="true" stripComments="false"><![CDATA[
ALTER TABLE character_class_levels
    DROP CONSTRAINT IF EXISTS fk_ccl_class;

ALTER TABLE character_skill_proficiencies
    DROP CONSTRAINT IF EXISTS fk_csp_skill;
]]></sql>
        <rollback>
            <sql splitStatements="true" stripComments="false"><![CDATA[
ALTER TABLE character_class_levels
    ADD CONSTRAINT fk_ccl_class FOREIGN KEY (class_id) REFERENCES character_classes(id);

ALTER TABLE character_skill_proficiencies
    ADD CONSTRAINT fk_csp_skill FOREIGN KEY (skill_id) REFERENCES proficiency_skills(id);
]]></sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
