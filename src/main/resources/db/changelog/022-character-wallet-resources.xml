<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Currency Types -->
    <changeSet id="022-create-currency-types" author="dnd-app">
        <createTable tableName="currency_types">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="exchange_rate_to_gold" type="decimal(10,4)"/>
            <column name="homebrew_id" type="uuid"/>
            <column name="is_default" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="currency_types"
                baseColumnNames="homebrew_id"
                referencedTableName="homebrew_packages"
                referencedColumnNames="id"
                constraintName="fk_currency_homebrew"
                onDelete="SET NULL"/>
    </changeSet>

    <!-- Character Wallets -->
    <changeSet id="022-create-character-wallets" author="dnd-app">
        <createTable tableName="character_wallets">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>
            <column name="character_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_wallet_character"
                             references="characters(id)"
                             deleteCascade="true"/>
            </column>
            <column name="currency_type_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="decimal(15,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="character_wallets"
                baseColumnNames="currency_type_id"
                referencedTableName="currency_types"
                referencedColumnNames="id"
                constraintName="fk_wallet_currency"
                onDelete="RESTRICT"/>

        <addUniqueConstraint tableName="character_wallets"
                             columnNames="character_id, currency_type_id"
                             constraintName="uq_wallet_char_currency"/>
    </changeSet>

    <!-- Custom Resource Types -->
    <changeSet id="022-create-custom-resource-types" author="dnd-app">
        <createTable tableName="custom_resource_types">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="max_value" type="int"/>
            <column name="homebrew_id" type="uuid"/>
            <column name="class_bound_id" type="uuid"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="custom_resource_types"
                baseColumnNames="homebrew_id"
                referencedTableName="homebrew_packages"
                referencedColumnNames="id"
                constraintName="fk_restype_homebrew"
                onDelete="SET NULL"/>

        <addForeignKeyConstraint
                baseTableName="custom_resource_types"
                baseColumnNames="class_bound_id"
                referencedTableName="character_classes"
                referencedColumnNames="id"
                constraintName="fk_restype_class"
                onDelete="SET NULL"/>
    </changeSet>

    <!-- Character Resources -->
    <changeSet id="022-create-character-resources" author="dnd-app">
        <createTable tableName="character_resources">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>
            <column name="character_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_charres_character"
                             references="characters(id)"
                             deleteCascade="true"/>
            </column>
            <column name="resource_type_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="current_value" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="character_resources"
                baseColumnNames="resource_type_id"
                referencedTableName="custom_resource_types"
                referencedColumnNames="id"
                constraintName="fk_charres_restype"
                onDelete="RESTRICT"/>

        <addUniqueConstraint tableName="character_resources"
                             columnNames="character_id, resource_type_id"
                             constraintName="uq_charres_char_restype"/>
    </changeSet>

</databaseChangeLog>
