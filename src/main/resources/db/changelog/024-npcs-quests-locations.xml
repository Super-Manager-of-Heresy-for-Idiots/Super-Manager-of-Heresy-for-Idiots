<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Campaign NPCs -->
    <changeSet id="024-create-campaign-npcs" author="dnd-app">
        <createTable tableName="campaign_npcs">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>
            <column name="campaign_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_npc_campaign"
                             references="campaigns(id)"
                             deleteCascade="true"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="is_visible_to_players" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="public_description" type="text"/>
            <column name="private_description" type="text"/>
            <column name="created_by" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="campaign_npcs"
                baseColumnNames="created_by"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_npc_creator"
                onDelete="RESTRICT"/>

        <createIndex tableName="campaign_npcs" indexName="idx_npc_campaign_id">
            <column name="campaign_id"/>
        </createIndex>
    </changeSet>

    <!-- NPC Notes -->
    <changeSet id="024-create-npc-notes" author="dnd-app">
        <createTable tableName="npc_notes">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>
            <column name="npc_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_npcnote_npc"
                             references="campaign_npcs(id)"
                             deleteCascade="true"/>
            </column>
            <column name="author_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="npc_notes"
                baseColumnNames="author_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_npcnote_author"
                onDelete="RESTRICT"/>
    </changeSet>

    <!-- Campaign Locations -->
    <changeSet id="024-create-campaign-locations" author="dnd-app">
        <createTable tableName="campaign_locations">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>
            <column name="campaign_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_location_campaign"
                             references="campaigns(id)"
                             deleteCascade="true"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="is_visible_to_players" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="campaign_locations"
                baseColumnNames="created_by"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_location_creator"
                onDelete="RESTRICT"/>

        <createIndex tableName="campaign_locations" indexName="idx_location_campaign_id">
            <column name="campaign_id"/>
        </createIndex>
    </changeSet>

    <!-- Campaign Quests -->
    <changeSet id="024-create-campaign-quests" author="dnd-app">
        <createTable tableName="campaign_quests">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>
            <column name="campaign_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_quest_campaign"
                             references="campaigns(id)"
                             deleteCascade="true"/>
            </column>
            <column name="title" type="varchar(200)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="status" type="varchar(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="is_visible_to_players" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="campaign_quests"
                baseColumnNames="created_by"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_quest_creator"
                onDelete="RESTRICT"/>

        <createIndex tableName="campaign_quests" indexName="idx_quest_campaign_id">
            <column name="campaign_id"/>
        </createIndex>
    </changeSet>

    <!-- Quest Notes -->
    <changeSet id="024-create-quest-notes" author="dnd-app">
        <createTable tableName="quest_notes">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>
            <column name="quest_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_questnote_quest"
                             references="campaign_quests(id)"
                             deleteCascade="true"/>
            </column>
            <column name="author_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="quest_notes"
                baseColumnNames="author_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_questnote_author"
                onDelete="RESTRICT"/>
    </changeSet>

    <!-- Quest Rewards -->
    <changeSet id="024-create-quest-rewards" author="dnd-app">
        <createTable tableName="quest_rewards">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>
            <column name="quest_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_questreward_quest"
                             references="campaign_quests(id)"
                             deleteCascade="true"/>
            </column>
            <column name="item_template_id" type="uuid"/>
            <column name="quantity" type="int" defaultValueNumeric="1"/>
            <column name="currency_type_id" type="uuid"/>
            <column name="currency_amount" type="decimal(15,2)"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="quest_rewards"
                baseColumnNames="item_template_id"
                referencedTableName="item_templates"
                referencedColumnNames="id"
                constraintName="fk_questreward_itemtpl"
                onDelete="SET NULL"/>

        <addForeignKeyConstraint
                baseTableName="quest_rewards"
                baseColumnNames="currency_type_id"
                referencedTableName="currency_types"
                referencedColumnNames="id"
                constraintName="fk_questreward_currency"
                onDelete="SET NULL"/>
    </changeSet>

    <!-- Quest NPCs -->
    <changeSet id="024-create-quest-npcs" author="dnd-app">
        <createTable tableName="quest_npcs">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>
            <column name="quest_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_questnpc_quest"
                             references="campaign_quests(id)"
                             deleteCascade="true"/>
            </column>
            <column name="npc_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_questnpc_npc"
                             references="campaign_npcs(id)"
                             deleteCascade="true"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="quest_npcs"
                             columnNames="quest_id, npc_id"
                             constraintName="uq_quest_npc"/>
    </changeSet>

    <!-- Quest Locations -->
    <changeSet id="024-create-quest-locations" author="dnd-app">
        <createTable tableName="quest_locations">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>
            <column name="quest_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_questloc_quest"
                             references="campaign_quests(id)"
                             deleteCascade="true"/>
            </column>
            <column name="location_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_questloc_location"
                             references="campaign_locations(id)"
                             deleteCascade="true"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="quest_locations"
                             columnNames="quest_id, location_id"
                             constraintName="uq_quest_location"/>
    </changeSet>

    <!-- Quest Items -->
    <changeSet id="024-create-quest-items" author="dnd-app">
        <createTable tableName="quest_items">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>
            <column name="quest_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_questitem_quest"
                             references="campaign_quests(id)"
                             deleteCascade="true"/>
            </column>
            <column name="item_template_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_questitem_itemtpl"
                             references="item_templates(id)"
                             deleteCascade="true"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="quest_items"
                             columnNames="quest_id, item_template_id"
                             constraintName="uq_quest_item"/>
    </changeSet>

    <!-- GM Session Notes -->
    <changeSet id="024-create-gm-session-notes" author="dnd-app">
        <createTable tableName="gm_session_notes">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>
            <column name="campaign_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_gmnotes_campaign"
                             references="campaigns(id)"
                             deleteCascade="true"/>
            </column>
            <column name="author_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="varchar(200)">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="gm_session_notes"
                baseColumnNames="author_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_gmnotes_author"
                onDelete="RESTRICT"/>

        <createIndex tableName="gm_session_notes" indexName="idx_gmnotes_campaign_id">
            <column name="campaign_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
