<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Add experience column, rename level → total_level -->
    <changeSet id="004-add-xp-rename-level" author="dnd-app">
        <addColumn tableName="characters">
            <column name="experience" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <renameColumn tableName="characters" oldColumnName="level" newColumnName="total_level"
                      columnDataType="int"/>
    </changeSet>

    <!-- Drop class_id FK from characters -->
    <changeSet id="004-drop-class-id-from-characters" author="dnd-app">
        <dropForeignKeyConstraint baseTableName="characters" constraintName="fk_char_class"/>
        <dropColumn tableName="characters" columnName="class_id"/>
    </changeSet>

    <!-- Create character_class_levels -->
    <changeSet id="004-create-character-class-levels" author="dnd-app">
        <createTable tableName="character_class_levels">
            <column name="character_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_ccl_char" references="characters(id)" deleteCascade="true"/>
            </column>
            <column name="class_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_ccl_class" references="character_classes(id)"/>
            </column>
            <column name="class_level" type="int" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="character_class_levels" columnNames="character_id, class_id"
                       constraintName="pk_character_class_levels"/>
    </changeSet>

    <!-- Create skills table -->
    <changeSet id="004-create-skills" author="dnd-app">
        <createTable tableName="skills">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="text"/>
            <column name="skill_type" type="varchar(50)"/>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Create subclasses table -->
    <changeSet id="004-create-subclasses" author="dnd-app">
        <createTable tableName="subclasses">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="class_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_subclass_class" references="character_classes(id)"/>
            </column>
            <column name="description" type="text"/>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Create feats table -->
    <changeSet id="004-create-feats" author="dnd-app">
        <createTable tableName="feats">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="text"/>
            <column name="prerequisites" type="text"/>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Create class_level_rewards table -->
    <changeSet id="004-create-class-level-rewards" author="dnd-app">
        <createTable tableName="class_level_rewards">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="class_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_clr_class" references="character_classes(id)"/>
            </column>
            <column name="required_level" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="reward_type" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
            <column name="reward_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="is_choice" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="class_level_rewards"
                             columnNames="class_id, required_level, reward_type, reward_id"
                             constraintName="uq_class_level_reward"/>
    </changeSet>

    <!-- Create character_acquired_rewards table -->
    <changeSet id="004-create-character-acquired-rewards" author="dnd-app">
        <createTable tableName="character_acquired_rewards">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="character_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_car_char" references="characters(id)" deleteCascade="true"/>
            </column>
            <column name="class_level_reward_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_car_clr" references="class_level_rewards(id)"/>
            </column>
            <column name="acquired_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="character_acquired_rewards"
                             columnNames="character_id, class_level_reward_id"
                             constraintName="uq_char_reward"/>
    </changeSet>

