<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="010-add-damage-to-item-types" author="dnd-app">
        <addColumn tableName="item_types">
            <column name="damage_dice" type="varchar(10)"/>
            <column name="damage_bonus" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="damage_type" type="varchar(20)"/>
            <column name="skill_id" type="uuid"/>
            <column name="skill_activation" type="varchar(10)"/>
        </addColumn>

        <addForeignKeyConstraint
                baseTableName="item_types"
                baseColumnNames="skill_id"
                referencedTableName="skills"
                referencedColumnNames="id"
                constraintName="fk_itemtype_skill"
                onDelete="SET NULL"/>
    </changeSet>

</databaseChangeLog>
