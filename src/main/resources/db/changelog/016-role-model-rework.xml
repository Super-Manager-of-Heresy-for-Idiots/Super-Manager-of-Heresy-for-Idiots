<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Add team_id to characters (nullable for existing data) -->
    <changeSet id="016-01-add-team-id-to-characters" author="dnd-app">
        <addColumn tableName="characters">
            <column name="team_id" type="uuid">
                <constraints nullable="true"
                             foreignKeyName="fk_characters_team"
                             referencedTableName="teams"
                             referencedColumnNames="id"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Add team_id to artifacts (nullable — ADMIN can create global artifacts) -->
    <changeSet id="016-02-add-team-id-to-artifacts" author="dnd-app">
        <addColumn tableName="artifacts">
            <column name="team_id" type="uuid">
                <constraints nullable="true"
                             foreignKeyName="fk_artifacts_team"
                             referencedTableName="teams"
                             referencedColumnNames="id"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Add team_id to conditions (nullable — ADMIN can create global conditions) -->
    <changeSet id="016-03-add-team-id-to-conditions" author="dnd-app">
        <addColumn tableName="conditions">
            <column name="team_id" type="uuid">
                <constraints nullable="true"
                             foreignKeyName="fk_conditions_team"
                             referencedTableName="teams"
                             referencedColumnNames="id"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Create team_homebrew_activations table -->
    <changeSet id="016-04-create-team-homebrew-activations" author="dnd-app">
        <createTable tableName="team_homebrew_activations">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="team_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_team_homebrew_act_team"
                             referencedTableName="teams"
                             referencedColumnNames="id"
                             deleteCascade="true"/>
            </column>
            <column name="homebrew_package_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_team_homebrew_act_package"
                             referencedTableName="homebrew_packages"
                             referencedColumnNames="id"/>
            </column>
            <column name="activated_at" type="timestamp" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="team_homebrew_activations"
                             columnNames="team_id, homebrew_package_id"
                             constraintName="uq_team_homebrew_activation"/>
    </changeSet>

</databaseChangeLog>
