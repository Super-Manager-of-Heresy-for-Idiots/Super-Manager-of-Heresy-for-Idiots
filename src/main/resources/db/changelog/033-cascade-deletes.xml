<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- ==================== 033-01: CharacterClass cascade ==================== -->
    <!-- Deleting a class cascades to: class_level_rewards, subclasses, character_class_levels -->

    <changeSet id="033-01-cascade-class-to-rewards" author="system">
        <dropForeignKeyConstraint baseTableName="class_level_rewards"
                                  constraintName="fk_clr_class"/>
        <addForeignKeyConstraint baseTableName="class_level_rewards"
                                 baseColumnNames="class_id"
                                 referencedTableName="character_classes"
                                 referencedColumnNames="id"
                                 constraintName="fk_clr_class"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="033-02-cascade-class-to-subclasses" author="system">
        <dropForeignKeyConstraint baseTableName="subclasses"
                                  constraintName="fk_subclass_class"/>
        <addForeignKeyConstraint baseTableName="subclasses"
                                 baseColumnNames="class_id"
                                 referencedTableName="character_classes"
                                 referencedColumnNames="id"
                                 constraintName="fk_subclass_class"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="033-03-cascade-class-to-character-class-levels" author="system">
        <dropForeignKeyConstraint baseTableName="character_class_levels"
                                  constraintName="fk_ccl_class"/>
        <addForeignKeyConstraint baseTableName="character_class_levels"
                                 baseColumnNames="class_id"
                                 referencedTableName="character_classes"
                                 referencedColumnNames="id"
                                 constraintName="fk_ccl_class"
                                 onDelete="CASCADE"/>
    </changeSet>

    <!-- ==================== 033-04: ClassLevelReward cascade ==================== -->
    <!-- Deleting a reward cascades to character_acquired_rewards -->

    <changeSet id="033-04-cascade-reward-to-acquired" author="system">
        <dropForeignKeyConstraint baseTableName="character_acquired_rewards"
                                  constraintName="fk_car_clr"/>
        <addForeignKeyConstraint baseTableName="character_acquired_rewards"
                                 baseColumnNames="class_level_reward_id"
                                 referencedTableName="class_level_rewards"
                                 referencedColumnNames="id"
                                 constraintName="fk_car_clr"
                                 onDelete="CASCADE"/>
    </changeSet>

    <!-- ==================== 033-05: Spell cascade ==================== -->
    <!-- Deleting a spell cascades to character_known_spells -->

    <changeSet id="033-05-cascade-spell-to-known" author="system">
        <dropForeignKeyConstraint baseTableName="character_known_spells"
                                  constraintName="fk_cks_spell"/>
        <addForeignKeyConstraint baseTableName="character_known_spells"
                                 baseColumnNames="spell_id"
                                 referencedTableName="spells"
                                 referencedColumnNames="id"
                                 constraintName="fk_cks_spell"
                                 onDelete="CASCADE"/>
    </changeSet>

    <!-- ==================== 033-06: ProficiencySkill cascade ==================== -->
    <!-- Deleting a proficiency skill cascades to character_skill_proficiencies -->

    <changeSet id="033-06-cascade-profskill-to-char" author="system">
        <dropForeignKeyConstraint baseTableName="character_skill_proficiencies"
                                  constraintName="fk_csp_skill"/>
        <addForeignKeyConstraint baseTableName="character_skill_proficiencies"
                                 baseColumnNames="skill_id"
                                 referencedTableName="proficiency_skills"
                                 referencedColumnNames="id"
                                 constraintName="fk_csp_skill"
                                 onDelete="CASCADE"/>
    </changeSet>

    <!-- ==================== 033-07: BuffDebuff cascade ==================== -->
    <!-- Deleting a buff/debuff cascades to skill_effects -->

    <changeSet id="033-07-cascade-buffdebuff-to-skilleffect" author="system">
        <dropForeignKeyConstraint baseTableName="skill_effects"
                                  constraintName="fk_skilleffect_buffdebuff"/>
        <addForeignKeyConstraint baseTableName="skill_effects"
                                 baseColumnNames="buff_debuff_id"
                                 referencedTableName="buffs_debuffs"
                                 referencedColumnNames="id"
                                 constraintName="fk_skilleffect_buffdebuff"
                                 onDelete="CASCADE"/>
    </changeSet>

    <!-- ==================== 033-08: Background → characters SET NULL ==================== -->
    <!-- Deleting a background nullifies characters.background_id -->

    <changeSet id="033-08-background-setnull" author="system">
        <dropForeignKeyConstraint baseTableName="characters"
                                  constraintName="fk_char_background"/>
        <addForeignKeyConstraint baseTableName="characters"
                                 baseColumnNames="background_id"
                                 referencedTableName="backgrounds"
                                 referencedColumnNames="id"
                                 constraintName="fk_char_background"
                                 onDelete="SET NULL"/>
    </changeSet>

</databaseChangeLog>
