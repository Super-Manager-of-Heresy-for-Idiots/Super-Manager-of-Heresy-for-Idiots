<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="051-create-campaign-blueprints" author="dnd-app">
        <createTable tableName="campaign_blueprints">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="author_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_blueprint_author" references="users(id)"/>
            </column>
            <column name="parent_id" type="uuid">
                <constraints foreignKeyName="fk_blueprint_parent" references="campaign_blueprints(id)"/>
            </column>
            <column name="origin_version" type="int"/>
            <column name="universe_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_blueprint_universe" references="universes(id)"/>
            </column>
            <column name="title" type="varchar(120)">
                <constraints nullable="false"/>
            </column>
            <column name="lore_description" type="text"/>
            <column name="status" type="varchar(20)" defaultValue="DRAFT">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="int" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="allow_forks" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="download_count" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="cover_url" type="text"/>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="published_at" type="timestamp with time zone"/>
            <column name="deleted_at" type="timestamp with time zone"/>
            <column name="deleted_by" type="uuid">
                <constraints foreignKeyName="fk_blueprint_deleted_by" references="users(id)"/>
            </column>
        </createTable>

        <createIndex tableName="campaign_blueprints" indexName="idx_blueprint_author_id">
            <column name="author_id"/>
        </createIndex>
        <createIndex tableName="campaign_blueprints" indexName="idx_blueprint_status">
            <column name="status"/>
        </createIndex>
        <createIndex tableName="campaign_blueprints" indexName="idx_blueprint_universe_id">
            <column name="universe_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
