<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Item Enchantments (for item_instances) -->
    <changeSet id="020-create-item-enchantments" author="dnd-app">
        <createTable tableName="item_enchantments">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>
            <column name="item_instance_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_itemench_instance"
                             references="item_instances(id)"
                             deleteCascade="true"/>
            </column>
            <column name="enchantment_type_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="applied_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="varchar(255)"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="item_enchantments"
                baseColumnNames="enchantment_type_id"
                referencedTableName="enchantment_types"
                referencedColumnNames="id"
                constraintName="fk_itemench_enchtype"
                onDelete="RESTRICT"/>

        <addUniqueConstraint tableName="item_enchantments"
                             columnNames="item_instance_id, enchantment_type_id"
                             constraintName="uq_item_enchantment"/>
    </changeSet>

    <!-- Add homebrew_id to enchantment_types -->
    <changeSet id="020-add-homebrew-to-enchantment-types" author="dnd-app">
        <addColumn tableName="enchantment_types">
            <column name="homebrew_id" type="uuid">
                <constraints foreignKeyName="fk_enchtype_homebrew"
                             references="homebrew_packages(id)"/>
            </column>
        </addColumn>

        <!-- SET NULL on delete for homebrew_id -->
        <sql>
            ALTER TABLE enchantment_types DROP CONSTRAINT IF EXISTS fk_enchtype_homebrew;
            ALTER TABLE enchantment_types ADD CONSTRAINT fk_enchtype_homebrew
                FOREIGN KEY (homebrew_id) REFERENCES homebrew_packages(id) ON DELETE SET NULL;
        </sql>
    </changeSet>

</databaseChangeLog>
