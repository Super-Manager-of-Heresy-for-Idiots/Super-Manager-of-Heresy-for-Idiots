<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      Phase 11/12 (roadmap R8a). The legacy level-up/reward cluster has been removed
      from the codebase: LevelUpService, RewardResolverRegistry + resolvers,
      ClassLevelReward / CharacterAcquiredReward entities and their repositories.
      No @Entity maps to these tables anymore, so ddl-auto:validate no longer needs
      them. Drop them now. The new reward model lives in character_reward_selection*.
      Idempotent (DROP TABLE IF EXISTS); CASCADE removes dependent FKs/data.
      Bestiary is untouched.
    -->
    <changeSet id="064-01-drop-legacy-reward-tables" author="content">
        <sql splitStatements="true" stripComments="false"><![CDATA[
DROP TABLE IF EXISTS character_acquired_rewards CASCADE;

DROP TABLE IF EXISTS class_level_rewards CASCADE;
]]></sql>
        <rollback>
            <comment>
                Irreversible by design: legacy reward tables are dropped after the
                runtime switched to character_reward_selection*. Restore from backup
                if rollback is required.
            </comment>
        </rollback>
    </changeSet>

</databaseChangeLog>
