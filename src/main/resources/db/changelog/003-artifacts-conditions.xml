<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="003-create-artifacts" author="dnd-app">
        <createTable tableName="artifacts">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="item_type_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_artifact_item_type" references="item_types(id)"/>
            </column>
            <column name="rarity" type="varchar(20)" defaultValue="COMMON">
                <constraints nullable="false"/>
            </column>
            <column name="properties" type="text"/>
            <column name="special_abilities" type="text"/>
            <column name="created_by" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_artifact_creator" references="users(id)"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="003-add-artifact-to-inventory" author="dnd-app">
        <addColumn tableName="inventory_slots">
            <column name="artifact_id" type="uuid">
                <constraints foreignKeyName="fk_inv_artifact" references="artifacts(id)"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="003-create-conditions" author="dnd-app">
        <createTable tableName="conditions">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="varchar(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="text"/>
            <column name="created_by" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_condition_creator" references="users(id)"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="003-create-condition-modifiers" author="dnd-app">
        <createTable tableName="condition_modifiers">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="condition_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_cm_condition" references="conditions(id)" deleteCascade="true"/>
            </column>
            <column name="stat_type_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_cm_stat_type" references="stat_types(id)"/>
            </column>
            <column name="modifier_value" type="int">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="condition_modifiers" columnNames="condition_id, stat_type_id"
                             constraintName="uq_cond_stat"/>
    </changeSet>

    <changeSet id="003-create-character-conditions" author="dnd-app">
        <createTable tableName="character_conditions">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="character_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_cc_character" references="characters(id)" deleteCascade="true"/>
            </column>
            <column name="condition_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_cc_condition" references="conditions(id)"/>
            </column>
            <column name="applied_by" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_cc_applied_by" references="users(id)"/>
            </column>
            <column name="applied_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
