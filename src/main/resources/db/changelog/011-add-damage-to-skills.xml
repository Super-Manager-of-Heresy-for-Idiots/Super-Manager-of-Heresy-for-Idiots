<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="011-add-damage-to-skills" author="dnd-app">
        <addColumn tableName="skills">
            <column name="damage_dice" type="varchar(10)"/>
            <column name="damage_bonus" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="damage_type" type="varchar(20)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
