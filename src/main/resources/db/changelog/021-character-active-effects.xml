<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Character Active Effects -->
    <changeSet id="021-create-character-active-effects" author="dnd-app">
        <createTable tableName="character_active_effects">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>
            <column name="character_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_cae_character"
                             references="characters(id)"
                             deleteCascade="true"/>
            </column>
            <column name="buff_debuff_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="applied_by" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="remaining_rounds" type="int"/>
            <column name="applied_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="character_active_effects"
                baseColumnNames="buff_debuff_id"
                referencedTableName="buffs_debuffs"
                referencedColumnNames="id"
                constraintName="fk_cae_buffdebuff"
                onDelete="RESTRICT"/>

        <addForeignKeyConstraint
                baseTableName="character_active_effects"
                baseColumnNames="applied_by"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_cae_applied_by"
                onDelete="RESTRICT"/>

        <createIndex tableName="character_active_effects" indexName="idx_cae_character_id">
            <column name="character_id"/>
        </createIndex>

        <createIndex tableName="character_active_effects" indexName="idx_cae_buff_debuff_id">
            <column name="buff_debuff_id"/>
        </createIndex>
    </changeSet>

    <!-- Add homebrew_id to buffs_debuffs -->
    <changeSet id="021-add-homebrew-to-buffs-debuffs" author="dnd-app">
        <addColumn tableName="buffs_debuffs">
            <column name="homebrew_id" type="uuid">
                <constraints foreignKeyName="fk_buffdebuff_homebrew"
                             references="homebrew_packages(id)"/>
            </column>
        </addColumn>

        <!-- SET NULL on delete for homebrew_id -->
        <sql>
            ALTER TABLE buffs_debuffs DROP CONSTRAINT IF EXISTS fk_buffdebuff_homebrew;
            ALTER TABLE buffs_debuffs ADD CONSTRAINT fk_buffdebuff_homebrew
                FOREIGN KEY (homebrew_id) REFERENCES homebrew_packages(id) ON DELETE SET NULL;
        </sql>
    </changeSet>

</databaseChangeLog>
