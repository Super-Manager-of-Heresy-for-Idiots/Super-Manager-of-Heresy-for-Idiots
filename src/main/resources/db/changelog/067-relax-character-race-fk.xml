<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      S2 (race -> species, D&D 2024): character creation now stores a NEW content-model
      species id in characters.race_id (snapshot rebuilt from species + background).
      The physical FK historically pointed at the legacy character_races table; it is
      relaxed (NO_CONSTRAINT semantics, mirroring fk_ccl_class in 060) so a species id
      can be stored without backfilling legacy rows. Legacy character_races is dropped
      in S5. Idempotent: drops only if present.
    -->
    <changeSet id="067-01-relax-character-race-fk" author="content">
        <sql splitStatements="true" stripComments="false"><![CDATA[
ALTER TABLE characters
    DROP CONSTRAINT IF EXISTS fk_char_race;
]]></sql>
        <rollback>
            <sql splitStatements="true" stripComments="false"><![CDATA[
ALTER TABLE characters
    ADD CONSTRAINT fk_char_race FOREIGN KEY (race_id) REFERENCES character_races(id);
]]></sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
