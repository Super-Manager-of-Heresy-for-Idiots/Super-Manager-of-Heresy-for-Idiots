<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      Business rule: every campaign-scoped entity is deleted together with its campaign.
      characters.campaign_id (added in 018) was the only campaign FK still created without an
      ON DELETE action, so deleting a campaign that still has characters was blocked. Recreate
      fk_characters_campaign with ON DELETE CASCADE, matching the other campaign FKs (024/049).
      Characters with campaign_id IS NULL (independent / Character Templates) are unaffected.
      A character's own children already cascade (stats, class levels, wallets, effects, known
      spells, combatants); item_instances owner is SET NULL by design.
    -->
    <changeSet id="070-01-cascade-delete-campaign-characters" author="content">
        <sql splitStatements="true" stripComments="false"><![CDATA[
ALTER TABLE characters DROP CONSTRAINT IF EXISTS fk_characters_campaign;
ALTER TABLE characters
    ADD CONSTRAINT fk_characters_campaign
    FOREIGN KEY (campaign_id) REFERENCES campaigns(id) ON DELETE CASCADE;
]]></sql>
        <rollback>
            <sql splitStatements="true" stripComments="false"><![CDATA[
ALTER TABLE characters DROP CONSTRAINT IF EXISTS fk_characters_campaign;
ALTER TABLE characters
    ADD CONSTRAINT fk_characters_campaign
    FOREIGN KEY (campaign_id) REFERENCES campaigns(id);
]]></sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
