<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      MINIO_PLAN Фаза 0: единая полиморфная таблица media_asset для картинок из MinIO
      (аватары персонажей, портреты NPC, обложки homebrew/blueprint и далее по списку).
      owner_type + owner_id адресуют владельца; UNIQUE(owner_type, owner_id) держит ОДИН слот
      картинки на владельца (замена перезаписывает слот). UNIQUE(bucket_name, storage_key) не даёт
      двум записям указывать на один объект. size_bytes > 0 отсекает пустые файлы. created_at с
      DEFAULT now() — на случай прямых SQL-вставок; JPA проставляет значение сам (@CreationTimestamp).
      Легаси-поля characters.avatar_url / campaign_blueprints.cover_url остаются как fallback и НЕ
      мигрируются — источник истины для картинок теперь эта таблица.
    -->
    <changeSet id="115-media-asset" author="claude">
        <sql splitStatements="true" stripComments="false"><![CDATA[
            CREATE TABLE IF NOT EXISTS public.media_asset (
                id                uuid        PRIMARY KEY,
                owner_type        text        NOT NULL,
                owner_id          uuid        NOT NULL,
                bucket_name       text        NOT NULL,
                storage_key       text        NOT NULL,
                original_filename text        NOT NULL,
                content_type      text        NOT NULL,
                size_bytes        bigint      NOT NULL CHECK (size_bytes > 0),
                width_px          int,
                height_px         int,
                checksum_sha256   text,
                uploaded_by       uuid        NOT NULL,
                created_at        timestamptz NOT NULL DEFAULT now(),
                CONSTRAINT uq_media_asset_owner  UNIQUE (owner_type, owner_id),
                CONSTRAINT uq_media_asset_object UNIQUE (bucket_name, storage_key)
            );

            CREATE INDEX IF NOT EXISTS idx_media_asset_uploaded_by ON public.media_asset (uploaded_by);
            CREATE INDEX IF NOT EXISTS idx_media_asset_owner ON public.media_asset (owner_type, owner_id);
        ]]></sql>
        <rollback>
            <sql splitStatements="true" stripComments="false"><![CDATA[
                DROP TABLE IF EXISTS public.media_asset;
            ]]></sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
