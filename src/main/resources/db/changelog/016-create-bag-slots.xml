<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="016-create-bag-slots" author="dnd-app">
        <createTable tableName="bag_slots">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true"/>
            </column>
            <column name="character_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_bag_slot_character"
                             references="characters(id)"
                             deleteCascade="true"/>
            </column>
            <column name="item_type_id" type="uuid">
                <constraints foreignKeyName="fk_bag_slot_item_type"
                             references="item_types(id)"/>
            </column>
            <column name="artifact_id" type="uuid">
                <constraints foreignKeyName="fk_bag_slot_artifact"
                             references="artifacts(id)"/>
            </column>
            <column name="quantity" type="int" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="varchar(255)"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="bag_slots"
                             columnNames="character_id, item_type_id"
                             constraintName="uq_bag_char_item_type"/>

        <addUniqueConstraint tableName="bag_slots"
                             columnNames="character_id, artifact_id"
                             constraintName="uq_bag_char_artifact"/>

        <sql>
            ALTER TABLE bag_slots ADD CONSTRAINT chk_bag_slot_has_content
                CHECK (item_type_id IS NOT NULL OR artifact_id IS NOT NULL);
            ALTER TABLE bag_slots ADD CONSTRAINT chk_bag_slot_not_both
                CHECK (NOT (item_type_id IS NOT NULL AND artifact_id IS NOT NULL));
            ALTER TABLE bag_slots ADD CONSTRAINT chk_bag_artifact_qty
                CHECK (artifact_id IS NULL OR quantity = 1);
        </sql>
    </changeSet>

</databaseChangeLog>
