<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      ASI — параметрическая награда без целевой сущности. Раньше seed заполнял
      reward_id случайным UUID (NOT NULL constraint), из-за чего резолвер падал
      с "Характеристика не найдена". Делаем reward_id nullable и обнуляем его
      у всех ASI-записей.
    -->
    <changeSet id="039-asi-reward-id-nullable" author="claude">
        <dropNotNullConstraint tableName="class_level_rewards"
                               columnName="reward_id"
                               columnDataType="uuid"/>
        <sql>
            UPDATE class_level_rewards
            SET reward_id = NULL
            WHERE reward_type = 'ABILITY_SCORE_IMPROVEMENT'
        </sql>
    </changeSet>

</databaseChangeLog>
