<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      Item source-of-truth unification. item_instances historically referenced the
      legacy item_templates table (template_id NOT NULL). The catalog and the new
      content model live in equipment_item / magic_item, so grant/inventory now
      reference those instead. We add two nullable content FKs, relax template_id to
      nullable (legacy rows keep it), and enforce that exactly one reference is set.
    -->
    <changeSet id="074-item-instances-content-fk" author="claude">
        <addColumn tableName="item_instances">
            <column name="equipment_item_id" type="uuid"/>
            <column name="magic_item_id" type="uuid"/>
        </addColumn>

        <dropNotNullConstraint tableName="item_instances"
                               columnName="template_id"
                               columnDataType="uuid"/>

        <addForeignKeyConstraint
                baseTableName="item_instances"
                baseColumnNames="equipment_item_id"
                referencedTableName="equipment_item"
                referencedColumnNames="equipment_item_id"
                constraintName="fk_iteminst_equipment_item"
                onDelete="RESTRICT"/>

        <addForeignKeyConstraint
                baseTableName="item_instances"
                baseColumnNames="magic_item_id"
                referencedTableName="magic_item"
                referencedColumnNames="magic_item_id"
                constraintName="fk_iteminst_magic_item"
                onDelete="RESTRICT"/>

        <createIndex tableName="item_instances" indexName="idx_iteminst_equipment_item_id">
            <column name="equipment_item_id"/>
        </createIndex>

        <createIndex tableName="item_instances" indexName="idx_iteminst_magic_item_id">
            <column name="magic_item_id"/>
        </createIndex>

        <sql>
            ALTER TABLE item_instances ADD CONSTRAINT chk_iteminst_one_ref CHECK (
                (CASE WHEN template_id IS NOT NULL THEN 1 ELSE 0 END
               + CASE WHEN equipment_item_id IS NOT NULL THEN 1 ELSE 0 END
               + CASE WHEN magic_item_id IS NOT NULL THEN 1 ELSE 0 END) = 1
            )
        </sql>

        <rollback>
            <sql>ALTER TABLE item_instances DROP CONSTRAINT IF EXISTS chk_iteminst_one_ref</sql>
            <dropForeignKeyConstraint baseTableName="item_instances" constraintName="fk_iteminst_equipment_item"/>
            <dropForeignKeyConstraint baseTableName="item_instances" constraintName="fk_iteminst_magic_item"/>
            <dropColumn tableName="item_instances" columnName="equipment_item_id"/>
            <dropColumn tableName="item_instances" columnName="magic_item_id"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
