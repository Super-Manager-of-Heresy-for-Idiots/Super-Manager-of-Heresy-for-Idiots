<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="012-create-skill-effects" author="dnd-app">
        <createTable tableName="skill_effects">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="skill_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="buff_debuff_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="effect_role" type="varchar(10)">
                <constraints nullable="false"/>
            </column>
            <column name="chance_percent" type="int" defaultValueNumeric="100">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="skill_effects"
                baseColumnNames="skill_id"
                referencedTableName="skills"
                referencedColumnNames="id"
                constraintName="fk_skilleffect_skill"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="skill_effects"
                baseColumnNames="buff_debuff_id"
                referencedTableName="buffs_debuffs"
                referencedColumnNames="id"
                constraintName="fk_skilleffect_buffdebuff"/>

        <addUniqueConstraint
                tableName="skill_effects"
                columnNames="skill_id, buff_debuff_id"
                constraintName="uq_skill_buffdebuff"/>
    </changeSet>

</databaseChangeLog>
