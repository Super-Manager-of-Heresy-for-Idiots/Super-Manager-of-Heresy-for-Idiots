<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      Soft delete for stat_types. A stat type is never hard-deleted through the
      application: deletion sets stat_types.deleted = true. Hard delete is only
      ever performed directly through the DBMS.

      New entities must not offer/use stat types with deleted = true. Every row
      that references a soft-deleted stat type is flagged deprecated = true so the
      UI can surface it. The four FK references to stat_types are:
        * character_stats.stat_type_id        (NOT NULL)
        * proficiency_skills.governing_stat_id (NOT NULL)
        * character_classes.primary_ability_stat_id / spellcasting_stat_id
        * buffs_debuffs.target_stat_id

      Postgres-only (boolean NOT NULL DEFAULT false).
    -->

    <changeSet id="046-01-stat-type-deleted-flag" author="content">
        <sql splitStatements="true" stripComments="false"><![CDATA[
            ALTER TABLE stat_types        ADD COLUMN deleted    boolean NOT NULL DEFAULT false;
            ALTER TABLE character_stats   ADD COLUMN deprecated boolean NOT NULL DEFAULT false;
            ALTER TABLE proficiency_skills ADD COLUMN deprecated boolean NOT NULL DEFAULT false;
            ALTER TABLE character_classes ADD COLUMN deprecated boolean NOT NULL DEFAULT false;
            ALTER TABLE buffs_debuffs     ADD COLUMN deprecated boolean NOT NULL DEFAULT false;
        ]]></sql>
    </changeSet>

</databaseChangeLog>
