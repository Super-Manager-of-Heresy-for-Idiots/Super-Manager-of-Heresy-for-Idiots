<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Homebrew Packages -->
    <changeSet id="005-create-homebrew-packages" author="dnd-app">
        <createTable tableName="homebrew_packages">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="author_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_homebrew_author" references="users(id)"/>
            </column>
            <column name="title" type="varchar(120)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="status" type="varchar(20)" defaultValue="DRAFT">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="int" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="download_count" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="published_at" type="timestamp with time zone"/>
            <column name="deleted_at" type="timestamp with time zone"/>
            <column name="deleted_by" type="uuid">
                <constraints foreignKeyName="fk_homebrew_deleted_by" references="users(id)"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Homebrew Tags -->
    <changeSet id="005-create-homebrew-tags" author="dnd-app">
        <createTable tableName="homebrew_tags">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="varchar(50)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_homebrew_tag_name"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Homebrew Package Tags (junction) -->
    <changeSet id="005-create-homebrew-package-tags" author="dnd-app">
        <createTable tableName="homebrew_package_tags">
            <column name="package_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_hpt_package" references="homebrew_packages(id)" deleteCascade="true"/>
            </column>
            <column name="tag_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_hpt_tag" references="homebrew_tags(id)"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="homebrew_package_tags" columnNames="package_id, tag_id"
                       constraintName="pk_homebrew_package_tags"/>
    </changeSet>

    <!-- Homebrew Content Items -->
    <changeSet id="005-create-homebrew-content-items" author="dnd-app">
        <createTable tableName="homebrew_content_items">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="package_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_hci_package" references="homebrew_packages(id)" deleteCascade="true"/>
            </column>
            <column name="content_type" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
            <column name="content_id" type="uuid">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="homebrew_content_items"
                             columnNames="package_id, content_type, content_id"
                             constraintName="uq_homebrew_content_item"/>
    </changeSet>

    <!-- Homebrew Installations -->
    <changeSet id="005-create-homebrew-installations" author="dnd-app">
        <createTable tableName="homebrew_installations">
            <column name="id" type="uuid">
                <constraints primaryKey="true"/>
            </column>
            <column name="package_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_hi_package" references="homebrew_packages(id)"/>
            </column>
            <column name="installer_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_hi_installer" references="users(id)"/>
            </column>
            <column name="installed_at" type="timestamp with time zone" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="source_version" type="int">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="homebrew_installations"
                             columnNames="package_id, installer_id"
                             constraintName="uq_homebrew_installation"/>
    </changeSet>

    <!-- Add owner_id to reference tables -->
    <changeSet id="005-add-owner-id-to-item-types" author="dnd-app">
        <addColumn tableName="item_types">
            <column name="owner_id" type="uuid">
                <constraints foreignKeyName="fk_item_type_owner" references="users(id)"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="005-add-owner-id-to-character-classes" author="dnd-app">
        <addColumn tableName="character_classes">
            <column name="owner_id" type="uuid">
                <constraints foreignKeyName="fk_char_class_owner" references="users(id)"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="005-add-owner-id-to-skills" author="dnd-app">
        <addColumn tableName="skills">
            <column name="owner_id" type="uuid">
                <constraints foreignKeyName="fk_skill_owner" references="users(id)"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="005-add-owner-id-to-feats" author="dnd-app">
        <addColumn tableName="feats">
            <column name="owner_id" type="uuid">
                <constraints foreignKeyName="fk_feat_owner" references="users(id)"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Add source_homebrew_id to reference tables (ON DELETE SET NULL) -->
    <changeSet id="005-add-source-homebrew-to-item-types" author="dnd-app">
        <addColumn tableName="item_types">
            <column name="source_homebrew_id" type="uuid">
                <constraints foreignKeyName="fk_item_type_homebrew" references="homebrew_packages(id)"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="005-add-source-homebrew-to-character-classes" author="dnd-app">
        <addColumn tableName="character_classes">
            <column name="source_homebrew_id" type="uuid">
                <constraints foreignKeyName="fk_char_class_homebrew" references="homebrew_packages(id)"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="005-add-source-homebrew-to-skills" author="dnd-app">
        <addColumn tableName="skills">
            <column name="source_homebrew_id" type="uuid">
                <constraints foreignKeyName="fk_skill_homebrew" references="homebrew_packages(id)"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="005-add-source-homebrew-to-feats" author="dnd-app">
        <addColumn tableName="feats">
            <column name="source_homebrew_id" type="uuid">
                <constraints foreignKeyName="fk_feat_homebrew" references="homebrew_packages(id)"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
