# Copy this file to .env and fill in real values.
# .env is git-ignored and must NEVER be committed.

# --- PostgreSQL ---
POSTGRES_DB=dndapp
POSTGRES_USER=dnd
# Use a strong unique password; this is consumed both by Postgres and by the app
POSTGRES_PASSWORD=replace_me_with_strong_password

# --- App / Spring datasource (used when running outside docker-compose) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/dndapp
SPRING_DATASOURCE_USERNAME=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD=${POSTGRES_PASSWORD}

# --- JWT ---
# At least 32 bytes of high-entropy random data (e.g. `openssl rand -base64 48`).
JWT_SECRET=
# 1 hour access tokens by default.
JWT_EXPIRATION_MS=3600000

# --- CORS ---
# Comma-separated allowlist for HTTP + WebSocket origins.
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate limiting ---
APP_RATELIMIT_LOGIN_PER_MIN=5
APP_RATELIMIT_REGISTER_PER_HOUR=3
